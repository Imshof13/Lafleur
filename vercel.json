{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://lafleuratory.vercel.app",
        "LOG_CHANNEL": "stderr",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "QUEUE_CONNECTION": "sync",
        "FILESYSTEM_DISK": "local",
        "APP_MAINTENANCE_DRIVER": "file",
        "VIEW_COMPILED_PATH": "/tmp/framework/views"
    },
    "buildCommand": "composer install --no-dev --optimize-autoloader && npm ci && npm run build",
    "builds": [
        {
            "src": "public/index.php",
            "use": "vercel-php@0.7.4"
        },
        {
            "src": "api/debug.php",
            "use": "vercel-php@0.7.4"
        },
        {
            "src": "api/laravel-debug.php",
            "use": "vercel-php@0.7.4"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/__debug",
            "dest": "/api/debug.php"
        },
        {
            "src": "/__laravel-debug",
            "dest": "/api/laravel-debug.php"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.php"
        }
    ]
}
